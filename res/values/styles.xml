<?xml version="1.0" encoding="utf-8"?>
<resources>
  <!-- Candidates view -->
  <style name="candidates_view">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:orientation">horizontal</item>
    <item name="android:gravity">center</item>
    <item name="android:paddingEnd">@dimen/candidates_gap</item>
  </style>
  <style name="candidates_item">
    <item name="android:layout_width">0dp</item>
    <item name="android:layout_height">match_parent</item>
    <item name="android:layout_weight">1</item>
    <item name="android:layout_marginStart">@dimen/candidates_gap</item>
    <item name="android:layout_marginTop">@dimen/candidates_margin_vertical</item>
    <item name="android:layout_marginBottom">@dimen/candidates_margin_vertical</item>
    <item name="android:padding">@dimen/candidates_suggestions_padding</item>
    <item name="android:gravity">center</item>
    <item name="android:textColor">?attr/colorLabel</item>
    <item name="android:maxLines">1</item>
  </style>
  <style name="candidates_separator">
    <item name="android:layout_width">wrap_content</item>
    <item name="android:layout_height">match_parent</item>
    <item name="android:layout_weight">0</item>
    <item name="android:gravity">center</item>
    <item name="android:text">|</item>
    <item name="android:textColor">?attr/colorLabel</item>
    <item name="android:alpha">0.45</item>
    <item name="android:maxLines">1</item>
  </style>
  <style name="candidates_emoji">
    <item name="android:layout_width">@dimen/candidates_emoji_width</item>
    <item name="android:layout_height">@dimen/candidates_emoji_width</item>
    <item name="android:layout_weight">0</item>
    <item name="android:layout_marginStart">@dimen/candidates_gap</item>
    <item name="android:padding">@dimen/candidates_suggestions_padding</item>
    <item name="android:gravity">center</item>
  </style>
  <style name="candidates_status">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:gravity">center</item>
    <item name="android:textColor">?attr/colorLabel</item>
  </style>
  <!-- Emoji pane -->
  <style name="emojiTypeButton">
    <item name="android:padding">4dp</item>
    <item name="android:gravity">center</item>
    <item name="android:minHeight">36dp</item>
    <item name="android:background">?attr/emoji_button_bg</item>
    <item name="android:textColor">?attr/emoji_key_text</item>
    <item name="android:textSize">22sp</item>
  </style>
  <style name="emojiGridButton">
    <item name="android:layout_width">fill_parent</item>
    <item name="android:layout_height">fill_parent</item>
    <item name="android:gravity">center</item>
    <item name="android:textSize">@dimen/emoji_text_size</item>
    <item name="android:textColor">?attr/emoji_color</item>
  </style>
  <!-- Clipboard pane -->
  <style name="clipboardTitle">
    <item name="android:layout_width">0dp</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:textSize">20dp</item>
    <item name="android:fontWeight">700</item>
    <item name="android:textColor">?attr/colorLabel</item>
  </style>
  <style name="clipboardToolbarLabel">
    <item name="android:layout_width">wrap_content</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginRight">6dp</item>
    <item name="android:textSize">12dp</item>
    <item name="android:textColor">?attr/colorSubLabel</item>
  </style>
  <style name="clipboardToolbarToggle">
    <item name="android:buttonTint">?attr/colorLabel</item>
  </style>
  <style name="clipboardHeading">
    <item name="android:layout_marginHorizontal">2dp</item>
    <item name="android:layout_marginTop">10dp</item>
    <item name="android:layout_marginBottom">6dp</item>
    <item name="android:textSize">13dp</item>
    <item name="android:fontWeight">700</item>
    <item name="android:textColor">?attr/colorSubLabel</item>
  </style>
  <style name="clipboardTipCard">
    <item name="android:orientation">vertical</item>
    <item name="android:layout_width">0dp</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_weight">1</item>
    <item name="android:layout_marginHorizontal">4dp</item>
    <item name="android:padding">14dp</item>
    <item name="android:background">@drawable/clipboard_card_background</item>
  </style>
  <style name="clipboardTipIcon">
    <item name="android:layout_width">28dp</item>
    <item name="android:layout_height">28dp</item>
    <item name="android:gravity">center</item>
    <item name="android:background">@drawable/clipboard_icon_background</item>
    <item name="android:textSize">15dp</item>
  </style>
  <style name="clipboardTipText">
    <item name="android:layout_width">fill_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginTop">10dp</item>
    <item name="android:textSize">15dp</item>
    <item name="android:textColor">?attr/colorLabel</item>
  </style>
  <style name="clipboardCard">
    <item name="android:layout_width">fill_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginHorizontal">4dp</item>
    <item name="android:padding">12dp</item>
    <item name="android:gravity">center_vertical</item>
    <item name="android:background">@drawable/clipboard_card_background</item>
  </style>
  <style name="clipboardCardIcon">
    <item name="android:layout_width">28dp</item>
    <item name="android:layout_height">28dp</item>
    <item name="android:layout_marginRight">10dp</item>
    <item name="android:gravity">center</item>
    <item name="android:background">@drawable/clipboard_icon_background</item>
    <item name="android:textSize">15dp</item>
  </style>
  <style name="clipboardEntry">
    <item name="android:layout_weight">1</item>
    <item name="android:layout_width">0dp</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:textSize">15dp</item>
    <item name="android:textColor">?attr/colorLabel</item>
  </style>
  <style name="clipboardEntryButtons">
    <item name="android:orientation">horizontal</item>
    <item name="android:layout_width">wrap_content</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_gravity">center_vertical</item>
    <item name="android:layout_marginLeft">10dp</item>
  </style>
  <style name="clipboardEntryButton">
    <item name="android:layout_width">24dp</item>
    <item name="android:layout_height">24dp</item>
    <item name="android:layout_marginHorizontal">3dp</item>
    <item name="android:backgroundTint">?attr/colorLabel</item>
    <item name="android:backgroundTintMode">src_in</item>
  </style>
  <style name="clipboardGridCard">
    <item name="android:layout_width">fill_parent</item>
    <item name="android:layout_height">@dimen/clipboard_grid_card_height</item>
    <item name="android:padding">10dp</item>
    <item name="android:background">@drawable/clipboard_card_background</item>
    <item name="android:clickable">true</item>
    <item name="android:focusable">true</item>
  </style>
  <style name="clipboardGridText">
    <item name="android:layout_width">fill_parent</item>
    <item name="android:layout_height">fill_parent</item>
    <item name="android:textSize">14dp</item>
    <item name="android:textColor">?attr/colorLabel</item>
    <item name="android:ellipsize">end</item>
    <item name="android:maxLines">5</item>
  </style>
  <style name="clipboardGridImage">
    <item name="android:layout_width">fill_parent</item>
    <item name="android:layout_height">fill_parent</item>
    <item name="android:scaleType">centerCrop</item>
  </style>
  <style name="clipboardGridButtons">
    <item name="android:orientation">horizontal</item>
    <item name="android:layout_width">wrap_content</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_gravity">bottom|right</item>
    <item name="android:background">@drawable/clipboard_icon_background</item>
    <item name="android:padding">2dp</item>
  </style>
  <style name="clipboardGridButton">
    <item name="android:layout_width">@dimen/clipboard_grid_button_size</item>
    <item name="android:layout_height">@dimen/clipboard_grid_button_size</item>
    <item name="android:layout_marginHorizontal">2dp</item>
    <item name="android:backgroundTint">?attr/colorLabel</item>
    <item name="android:backgroundTintMode">src_in</item>
  </style>
  <style name="clipboardEditorAction">
    <item name="android:layout_width">36dp</item>
    <item name="android:layout_height">36dp</item>
    <item name="android:gravity">center</item>
    <item name="android:textSize">22dp</item>
    <item name="android:textColor">?attr/colorLabel</item>
    <item name="android:background">@drawable/clipboard_icon_background</item>
  </style>
  <!-- Launcher activity -->
  <style name="paragraph">
    <item name="android:layout_width">fill_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginVertical">8dp</item>
    <item name="android:layout_marginHorizontal">24dp</item>
    <item name="android:layout_gravity">center</item>
  </style>
  <style name="launcher_intro">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginHorizontal">24dp</item>
    <item name="android:layout_marginTop">20dp</item>
    <item name="android:layout_marginBottom">12dp</item>
    <item name="android:textColor">#A8B2BE</item>
    <item name="android:textSize">16sp</item>
  </style>
  <style name="launcher_setup_button">
    <item name="android:layout_width">wrap_content</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_margin">4dp</item>
    <item name="android:minHeight">48dp</item>
    <item name="android:minWidth">92dp</item>
    <item name="android:paddingHorizontal">10dp</item>
    <item name="android:textSize">13sp</item>
  </style>
  <style name="launcher_heading">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginHorizontal">24dp</item>
    <item name="android:layout_marginTop">22dp</item>
    <item name="android:layout_marginBottom">8dp</item>
    <item name="android:textColor">#F4F7FA</item>
    <item name="android:textSize">18sp</item>
    <item name="android:textStyle">bold</item>
  </style>
  <style name="launcher_card">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginHorizontal">24dp</item>
    <item name="android:background">@drawable/launcher_card</item>
  </style>
  <style name="launcher_card_title">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:textColor">#F4F7FA</item>
    <item name="android:textSize">15sp</item>
    <item name="android:textStyle">bold</item>
  </style>
  <style name="launcher_card_body">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginTop">4dp</item>
    <item name="android:textColor">#A8B2BE</item>
    <item name="android:textSize">14sp</item>
  </style>
  <style name="launcher_accent_text">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginTop">12dp</item>
    <item name="android:textColor">#8CE9D7</item>
    <item name="android:textSize">14sp</item>
    <item name="android:textStyle">bold</item>
  </style>
  <style name="launcher_direction_map">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:gravity">center</item>
    <item name="android:lineSpacingExtra">6dp</item>
    <item name="android:textColor">#8CE9D7</item>
    <item name="android:textSize">14sp</item>
    <item name="android:textStyle">bold</item>
  </style>
  <style name="launcher_feature_card" parent="launcher_card_body">
    <item name="android:layout_marginHorizontal">24dp</item>
    <item name="android:layout_marginTop">0dp</item>
    <item name="android:background">@drawable/launcher_card</item>
  </style>
  <style name="launcher_try_area">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginHorizontal">24dp</item>
    <item name="android:background">@drawable/launcher_input</item>
    <item name="android:minHeight">52dp</item>
    <item name="android:textColor">#F4F7FA</item>
    <item name="android:textColorHint">#A8B2BE</item>
    <item name="android:textSize">15sp</item>
  </style>
  <style name="launcher_privacy_card" parent="launcher_card">
    <item name="android:layout_marginTop">22dp</item>
    <item name="android:background">@drawable/launcher_privacy_card</item>
  </style>
  <style name="launcher_source">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginHorizontal">24dp</item>
    <item name="android:layout_marginTop">8dp</item>
    <item name="android:gravity">center</item>
    <item name="android:textColor">#68A8FF</item>
    <item name="android:textSize">12sp</item>
  </style>
  <!-- Dictionaries activity -->
  <style name="dictionary_list_view">
    <item name="android:layout_width">fill_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginVertical">24dp</item>
  </style>
  <style name="dictionary_download_item">
    <item name="android:orientation">horizontal</item>
    <item name="android:layout_width">fill_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginVertical">8dp</item>
    <item name="android:gravity">center</item>
    <item name="android:paddingHorizontal">48dp</item>
  </style>
  <style name="dictionary_download_locale">
    <item name="android:layout_weight">1</item>
    <item name="android:layout_width">fill_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:textSize">16sp</item>
  </style>
  <style name="dictionary_download_size">
    <item name="android:layout_weight">0</item>
    <item name="android:layout_width">wrap_content</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginRight">8dp</item>
    <item name="android:textSize">12sp</item>
  </style>
  <style name="dictionary_download_button">
    <item name="android:layout_width">24dp</item>
    <item name="android:layout_height">24dp</item>
  </style>
  <style name="appTheme" parent="@android:style/Theme.Material.Light"/>
  <style name="launcherTheme" parent="@android:style/Theme.Material">
    <item name="android:colorAccent">#55D6BE</item>
    <item name="android:navigationBarColor">#0B0D10</item>
    <item name="android:windowActionModeOverlay">true</item>
    <item name="android:windowBackground">#0B0D10</item>
  </style>
  <style name="settingsTheme" parent="@android:style/Theme.Material">
    <!-- Setting this in the activity theme so it propagate to nested
         preference screens. -->
    <item name="android:fitsSystemWindows">true</item>
    <item name="android:colorAccent">#55D6BE</item>
    <item name="android:navigationBarColor">#0B0D10</item>
    <item name="android:windowBackground">#0B0D10</item>
  </style>
</resources>
