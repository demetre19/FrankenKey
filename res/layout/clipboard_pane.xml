<?xml version="1.0" encoding="utf-8"?>
<juloo.keyboard2.ClipboardPanelView xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:background="?attr/colorKeyboard" android:hardwareAccelerated="false">
  <LinearLayout android:id="@+id/clipboard_drag_handle" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="12dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_width="fill_parent" android:layout_height="wrap_content" android:clickable="true" android:focusable="true">
    <TextView android:text="⌨" style="@style/clipboardToolbarLabel" android:textSize="18dp"/>
    <TextView android:text="|" style="@style/clipboardToolbarLabel"/>
    <TextView android:text="@string/clipboard_panel_title" style="@style/clipboardTitle" android:layout_weight="1"/>
    <TextView android:text="@string/clipboard_history_toggle_label" style="@style/clipboardToolbarLabel"/>
    <juloo.keyboard2.ClipboardHistoryCheckBox android:contentDescription="@string/clipboard_history_toggle_label" style="@style/clipboardToolbarToggle" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
  </LinearLayout>

  <juloo.keyboard2.ClipboardItemEditorView android:id="@+id/clipboard_item_editor" android:visibility="gone" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="10dp" android:paddingBottom="8dp" android:layout_width="fill_parent" android:layout_height="wrap_content">
    <EditText android:id="@+id/clipboard_editor_text" android:hint="@string/clipboard_editor_hint" android:singleLine="false" android:maxLines="4" android:inputType="textMultiLine|textCapSentences" android:textColor="?attr/colorLabel" android:textColorHint="?attr/colorSubLabel" android:background="@drawable/clipboard_card_background" android:padding="10dp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
    <TextView android:id="@+id/clipboard_editor_paste" android:text="➜" android:contentDescription="@string/clipboard_editor_paste" style="@style/clipboardEditorAction" android:layout_marginLeft="8dp"/>
    <TextView android:id="@+id/clipboard_editor_close" android:text="×" android:contentDescription="@string/clipboard_editor_close" style="@style/clipboardEditorAction" android:layout_marginLeft="6dp"/>
  </juloo.keyboard2.ClipboardItemEditorView>

  <ScrollView android:id="@+id/clipboard_scroll" android:layout_width="fill_parent" android:layout_height="@dimen/clipboard_view_height" android:clipToPadding="false" android:paddingHorizontal="10dp" android:paddingBottom="10dp">
    <LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="wrap_content">
      <LinearLayout android:id="@+id/clipboard_tips_section" android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <TextView android:text="@string/clipboard_tips_heading" style="@style/clipboardHeading" android:layout_width="fill_parent" android:layout_height="wrap_content"/>
        <LinearLayout android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content" android:baselineAligned="false">
          <LinearLayout style="@style/clipboardTipCard">
            <TextView android:text="📋" style="@style/clipboardTipIcon"/>
            <TextView android:text="@string/clipboard_tip_paste" style="@style/clipboardTipText"/>
          </LinearLayout>
          <LinearLayout style="@style/clipboardTipCard">
            <TextView android:text="📌" style="@style/clipboardTipIcon"/>
            <TextView android:text="@string/clipboard_tip_pin" style="@style/clipboardTipText"/>
          </LinearLayout>
        </LinearLayout>
      </LinearLayout>
      <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <TextView android:text="@string/clipboard_history_heading" style="@style/clipboardHeading" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <TextView android:id="@+id/clipboard_show_more" android:text="@string/clipboard_show_more" style="@style/clipboardToolbarLabel" android:padding="8dp" android:clickable="true" android:focusable="true"/>
      </LinearLayout>
      <juloo.keyboard2.ClipboardHistoryView android:layout_width="fill_parent" android:layout_height="wrap_content" android:cacheColorHint="@android:color/transparent"/>
      <TextView android:text="@string/clipboard_pin_heading" style="@style/clipboardHeading" android:layout_width="fill_parent" android:layout_height="wrap_content"/>
      <juloo.keyboard2.ClipboardPinView android:id="@+id/clipboard_pin_view" android:layout_width="fill_parent" android:layout_height="wrap_content" android:cacheColorHint="@android:color/transparent"/>
    </LinearLayout>
  </ScrollView>
  <juloo.keyboard2.Keyboard2View layout="@xml/clipboard_bottom_row" android:layout_width="fill_parent" android:layout_height="wrap_content" android:background="?attr/colorKeyboard"/>
</juloo.keyboard2.ClipboardPanelView>
